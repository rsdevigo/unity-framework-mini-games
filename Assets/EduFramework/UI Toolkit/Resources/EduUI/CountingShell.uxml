<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="False">
    <Style src="Theme.uss" />
    <ui:VisualElement name="counting-root" picking-mode="Position" class="edu-safe-area edu-feedback-root" style="flex-grow: 1; background-color: rgb(24, 28, 36); align-items: center; justify-content: center; flex-direction: column; padding: 40px;">
        <ui:Label name="prompt-label" text="?" style="font-size: 42px; color: rgb(248, 248, 252); margin-bottom: 24px; -unity-text-align: middle-center;" />
        <ui:VisualElement name="numbers-row" picking-mode="Position" style="flex-direction: row; flex-wrap: wrap; justify-content: center; align-items: center;" />
    </ui:VisualElement>
</ui:UXML>
